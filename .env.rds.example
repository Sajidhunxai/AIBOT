# =============================================================================
# AIBotTrade — AWS / RDS production template
# Copy to .env on your server and fill in values.
# =============================================================================

APP_ENV=production
LOG_LEVEL=INFO
LOG_DIR=logs
CONFIG_PATH=config/default.yaml

# live | testnet | paper
TRADING_MODE=testnet

# --- Binance Futures API ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true

# --- AWS RDS PostgreSQL ---
# Replace host, user, password, and dbname with your RDS endpoint details.
# async driver for the app:
DATABASE_URL=postgresql+asyncpg://aibottrade:CHANGE_ME@your-db.xxxxx.ap-southeast-1.rds.amazonaws.com:5432/aibottrade
# sync driver for Alembic migrations:
DATABASE_SYNC_URL=postgresql://aibottrade:CHANGE_ME@your-db.xxxxx.ap-southeast-1.rds.amazonaws.com:5432/aibottrade

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
# Public URL of your dashboard (for CORS). Use your domain or EC2 public IP.
API_CORS_ORIGINS=http://your-server-ip:3000,https://your-domain.com

# --- Dashboard ---
# Browser-facing API URL (same host users use to open the dashboard).
NEXT_PUBLIC_API_URL=http://your-server-ip:8000

# --- Telegram (optional) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI Filter (optional) ---
AI_FILTER_ENABLED=false
AI_MODEL_PATH=models/trade_filter.joblib

STATE_FILE=data/bot_state.json
RESUME_ON_START=true

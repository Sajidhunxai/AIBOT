# =============================================================================
# AIBotTrade Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
LOG_DIR=logs
CONFIG_PATH=config/default.yaml

# --- Trading Mode ---
# live | testnet | paper
TRADING_MODE=testnet

# --- Binance Futures API ---
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true

# For AWS RDS deployment, see .env.rds.example
# For local dev without Docker, SQLite is used automatically below.
# DATABASE_URL=postgresql+asyncpg://aibottrade:aibottrade@localhost:5432/aibottrade
# DATABASE_SYNC_URL=postgresql://aibottrade:aibottrade@localhost:5432/aibottrade
DATABASE_URL=sqlite+aiosqlite:///./data/aibottrade.db
DATABASE_SYNC_URL=sqlite:///./data/aibottrade.db

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Telegram Notifications ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- AI Filter ---
AI_FILTER_ENABLED=false
AI_MODEL_PATH=models/trade_filter.joblib

# --- Risk Overrides (optional, YAML takes precedence) ---
# MAX_DAILY_LOSS_PCT=3.0
# MAX_DRAWDOWN_PCT=10.0
# MAX_CONCURRENT_POSITIONS=4
# MAX_POSITIONS_PER_SYMBOL=1
# MAX_UNREALIZED_LOSS_PCT=5.0
# EMERGENCY_CLOSE_UNREALIZED_LOSS_PCT=8.0

# --- Recovery ---
STATE_FILE=data/bot_state.json
RESUME_ON_START=true
